# SharePoint Batch Write Optimization
# Copy these to your Azure App Settings or local .env file

# Increase concurrent batch writes from 4 to 10 (2.5x faster)
# Trade-off: Higher risk of 503 throttling from SharePoint
SHAREPOINT_BATCH_CONCURRENCY=10
SHAREPOINT_BATCH_CONCURRENCY_SNAPSHOTS=10

# Keep batch size at 20 (Graph API limit)
SHAREPOINT_BATCH_SIZE=20
SHAREPOINT_BATCH_SIZE_SNAPSHOTS=20

# Expected improvement for Cobalt Row:
# Before: 250 batches ÷ 4 concurrency = 62.5 waves × 3.5s = 218s
# After:  250 batches ÷ 10 concurrency = 25 waves × 3.5s = 87s
# Savings: ~130 seconds (290s → 160s total)

# To apply on Azure:
# 1. Azure Portal → App Service → Configuration → Application settings
# 2. Add each variable above
# 3. Restart app service
# 4. Monitor for 503 errors in logs - if too many, reduce to 8 or 6
